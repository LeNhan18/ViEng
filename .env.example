# OpenAI API (dùng cho prototype, thay bằng local LLM sau)
OPENAI_API_KEY=sk-your-key-here

# Groq API (alternative, chạy Llama-3 miễn phí)
GROQ_API_KEY=gsk_your-key-here

# App config
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# ChromaDB
CHROMA_PERSIST_DIR=./data/vectorstore

# Embedding model
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
